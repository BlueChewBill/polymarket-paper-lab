# Paper-trader account
PM_ACCOUNT=sumarb
INITIAL_BALANCE_USD=500

# Scanner params
# SUM_THRESHOLD rationale: break-even pre-fee is 0.933 (7.2% taker each
# leg). Observed slippage: median +500 bps, p75 +943 bps. 0.86 gives a
# ~2% post-fee edge on median-slippage fills. At 0.99, 0 / 45 live
# filled trades had positive post-fee edge -- phantom chase. Raise
# only if you want to stress-test the wider-edge tail.
SUM_THRESHOLD=0.86
MIN_DEPTH_USD=15
MAX_HOURS_OUT=2

# Sizing
TRADE_NOTIONAL_USD=5
